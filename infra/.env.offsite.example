# Off-site backup configuration for offsite-sync.sh.
#
# Copy this file to infra/.env.offsite and fill in your remote.
# install-offsite.sh writes it automatically if you let it.
#
# Format: <rclone-remote-name>:<bucket-or-path>
# The remote-name part must match what you chose during `rclone config`.

# === Pick ONE example below ===

# Backblaze B2 (cheapest, free egress to Cloudflare):
# OFFSITE_REMOTE=b2:realtorai-backups

# Cloudflare R2 (zero egress, S3-compatible):
# OFFSITE_REMOTE=r2:realtorai-backups

# Oracle Object Storage (always-free 20GB):
# OFFSITE_REMOTE=oci:realtorai-backups

# AWS S3 / Wasabi / any S3-compatible:
# OFFSITE_REMOTE=s3:realtorai-backups

# SFTP to a second VPS:
# OFFSITE_REMOTE=second-vps:/backups/realtorai

OFFSITE_REMOTE=
