# Copy to apps/api/.env and adjust before running the API.
NODE_ENV=development
PORT=3000

# CORS allowed origins (comma-separated). Use "*" only for dev.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database - must match infra/.env
DATABASE_URL=postgresql://realtorai:change-me-postgres@localhost:5432/realtorai?schema=public

# Test database (separate schema in the same Postgres instance)
DATABASE_URL_TEST=postgresql://realtorai:change-me-postgres@localhost:5432/realtorai?schema=test

# Redis
REDIS_URL=redis://default:change-me-redis@localhost:6379

# JWT - generate with `openssl rand -hex 64`
JWT_SECRET=change-me-jwt-secret-must-be-at-least-32-bytes-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Bcrypt
BCRYPT_ROUNDS=12

# Throttling (auth endpoints)
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=5

# Log level: trace | debug | info | warn | error
LOG_LEVEL=debug

# LLM providers (all optional — mock fallback if absent)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# WhatsApp: mock | twilio | meta | dialog360
WHATSAPP_PROVIDER=mock
WHATSAPP_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=

DIALOG360_API_KEY=
DIALOG360_BASE_URL=

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
