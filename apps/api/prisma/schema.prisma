// Realtorai Prisma schema — Sprint 2
// Multi-tenant SaaS for real estate offices.
// All tenant-owned models carry tenantId. Tenant scoping is enforced at runtime
// by PrismaService's client extension (see src/prisma/tenant-extension.ts).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  platform_owner
  platform_admin
  ceo
  deputy_ceo
  district_manager
  branch_manager
  office_owner
  office_manager
  team_lead
  realtor
  mortgage_advisor
  marketing_manager
  secretary
  accountant
  viewer
}

enum TenantStatus {
  active
  suspended
  trial
}

enum OfficeStatus {
  active
  inactive
}

enum UserStatus {
  active
  invited
  disabled
}

enum OptOutChannel {
  whatsapp
  call
  sms
  email
}

enum LeadStatus {
  new
  contacted
  qualified
  hot
  meeting_scheduled
  not_relevant
  no_answer
  opted_out
  handoff_to_human
}

enum LeadTemperature {
  cold
  warm
  hot
}

enum LeadIntent {
  buy
  sell
  rent
  list_for_rent
  unknown
}

enum PropertyDealType {
  sale
  rent
}

enum PropertyCondition {
  new
  excellent
  good
  needs_renovation
  for_demolition
}

enum PropertyStatus {
  draft
  active
  pending
  sold
  rented
  withdrawn
}

enum ConversationChannel {
  whatsapp
  voice
  web
  form
  manual
}

enum ConversationStatus {
  active
  waiting
  closed
  handoff
}

enum MessageSenderType {
  lead
  user
  ai_agent
  system
}

enum TaskStatus {
  open
  in_progress
  done
  cancelled
  snoozed
}

enum TaskType {
  followup
  call_lead
  visit
  send_property
  mortgage_followup
  custom
}

enum MortgageStatus {
  unknown
  not_relevant
  needs_advisor
  referred
  contacted_by_advisor
  pre_approved
  declined
}

enum MortgageReadiness {
  unknown
  not_ready
  partial
  ready
  approved
}

enum ReferralStatus {
  pending
  contacted
  qualified
  in_process
  closed_won
  closed_lost
  declined
}

enum TaskCreatedByType {
  user
  ai_agent
  system
}

enum AgentType {
  lead_responder
  property_recruiter
  crm_followup
  qa_agent
  support_agent
  mortgage_intake
}

enum AgentStatus {
  active
  paused
  disabled
}

enum UsageEventType {
  llm_tokens
  whatsapp_message
  call_minute
  voice_session
  storage
}

enum NotificationSeverity {
  info
  warning
  alert
}

enum NotificationType {
  hot_lead
  handoff_required
  followup_due
  daily_summary
  system
  contact_request
  mortgage_referred
  mortgage_pre_approved
  mortgage_not_relevant
  mortgage_advisor_idle
}

enum ContactRequestStatus {
  new
  contacted
  qualified
  converted
  closed
}

model ContactRequest {
  id              String               @id @default(uuid())
  fullName        String
  officeName      String?
  phone           String?
  email           String
  city            String?
  message         String?
  source          String?
  ipHash          String?
  status          ContactRequestStatus @default(new)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  handledAt       DateTime?
  handledByUserId String?

  @@index([status, createdAt])
  @@index([email])
  @@map("contact_requests")
}

model Tenant {
  id                  String       @id @default(uuid())
  name                String
  status              TenantStatus @default(trial)
  // `plan` is a free-text legacy field that pre-dates the PlanCatalog FK below.
  // New code should populate `planCatalogId` and treat `plan` as a denormalized
  // slug copy for read-only display. Both stay in sync via AdminService.
  plan                String       @default("starter")
  planCatalogId       String?
  planCatalog         PlanCatalog? @relation(fields: [planCatalogId], references: [id], onDelete: SetNull)
  // Billing (per spec section 21) — all in ILS agorot or count.
  setupFeeIls         Int          @default(0)
  monthlyPlanIls      Int          @default(0)
  includedMessages    Int          @default(0)
  includedCallMinutes Int          @default(0)
  extraMessageIls     Decimal      @default(0) @db.Decimal(8, 2)
  extraCallMinuteIls  Decimal      @default(0) @db.Decimal(8, 2)
  successFeePct       Decimal      @default(0) @db.Decimal(5, 2)
  // Hard cap on USD spent on LLM calls per calendar month. 0 = unlimited.
  // Enforced by BillingService.checkLlmBudget before LlmRouterService.chat().
  monthlyLlmBudgetUsd Decimal      @default(0) @db.Decimal(10, 4)
  billingNotes        String?
  // Suspension metadata — written by AdminService.suspendTenant / reactivate.
  // The hard enforcement lives in TenantStatusGuard which gates every non-
  // exempt request on `status === 'suspended'`. Fields here are denormalized
  // for the admin UI (so it doesn't have to dig through AuditLog every time).
  suspendedAt         DateTime?
  suspendedReason     String?
  suspendedByUserId   String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  offices           Office[]
  users             User[]
  auditLogs         AuditLog[]
  optOuts           OptOut[]
  leads             Lead[]
  properties        Property[]
  conversations     Conversation[]
  messages          Message[]
  tasks             Task[]
  agents            Agent[]
  agentConfigs      AgentConfig[]
  usageEvents       UsageEvent[]
  notifications     Notification[]
  mortgageAdvisors  MortgageAdvisor[]
  mortgageProfiles  MortgageProfile[]
  mortgageReferrals MortgageReferral[]
  networks          Network[]
  districts         District[]
  branches          Branch[]
  signDocuments     SignDocument[]
  webhookEndpoints  WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]

  @@index([planCatalogId])
  @@map("tenants")
}

// ---------------------------------------------------------------------------
// Organizational hierarchy: Network → District → Branch → Office
// Backwards-compatible: ALL fields are nullable on Office, so existing single-
// office tenants don't need to fill in any of them. Multi-branch tenants
// (e.g. a chain of franchises) populate the hierarchy and gain scoping for
// district_manager / branch_manager roles.
// ---------------------------------------------------------------------------

model Network {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  districts District[]
  branches  Branch[]
  offices   Office[]

  @@index([tenantId])
  @@map("networks")
}

model District {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  networkId String?
  network   Network? @relation(fields: [networkId], references: [id], onDelete: SetNull)
  name      String
  region    String? // e.g. "מרכז", "צפון" — free text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]
  offices  Office[]

  @@index([tenantId])
  @@index([networkId])
  @@map("districts")
}

model Branch {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  networkId  String?
  network    Network?  @relation(fields: [networkId], references: [id], onDelete: SetNull)
  districtId String?
  district   District? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  name       String
  city       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  offices Office[]

  @@index([tenantId])
  @@index([districtId])
  @@index([networkId])
  @@map("branches")
}

model Office {
  id                  String       @id @default(uuid())
  tenantId            String
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Optional org-chart links. NULL on single-office tenants. When set, the
  // ScopingService grants visibility to the matching branch/district/network
  // managers without changing tenant scoping (tenantId is the hard wall).
  branchId            String?
  branch              Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  districtId          String?
  district            District?    @relation(fields: [districtId], references: [id], onDelete: SetNull)
  networkId           String?
  network             Network?     @relation(fields: [networkId], references: [id], onDelete: SetNull)
  name                String
  city                String?
  // Legacy free-text area list. Kept for backward-compat — new code writes to
  // the OfficeArea junction below. A future migration will drop this column.
  areas               String[]     @default([])
  phone               String?
  whatsappNumber      String?
  status              OfficeStatus @default(active)
  // Inactivation metadata — set by AdminService.deactivateOffice. The hard
  // enforcement lives in OfficeStatusGuard. status=inactive blocks every
  // request that requires officeId scoping (but leaves tenant-level routes
  // free, since other offices in the same tenant may still be active).
  inactivatedAt       DateTime?
  inactivatedReason   String?
  inactivatedByUserId String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  users         User[]
  leads         Lead[]
  properties    Property[]
  conversations Conversation[]
  tasks         Task[]
  agents        Agent[]
  usageEvents   UsageEvent[]
  notifications Notification[]
  areaLinks     OfficeArea[]

  @@index([tenantId])
  @@index([branchId])
  @@index([districtId])
  @@index([networkId])
  @@map("offices")
}

// ---------------------------------------------------------------------------
// Catalog tables — globally-shared lookup data (not per-tenant). Maintained by
// platform_admin via /admin/catalog/* endpoints. Tenants reference them via
// FKs (Tenant.planCatalogId, OfficeArea.areaId).
// ---------------------------------------------------------------------------

model AreaCatalog {
  id        String   @id @default(uuid())
  // Stable slug — never changes after creation even if nameHe is corrected.
  // External integrations (CSV imports, future API) anchor on slug.
  slug      String   @unique
  nameHe    String
  nameEn    String?
  // Coarse region for grouping in selects ("מרכז" / "צפון" / "דרום" / ...).
  region    String?
  // Soft-delete: keep history but hide from new selects.
  active    Boolean  @default(true)
  // Lower numbers float to the top of the cmdk multi-select.
  sortOrder Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offices OfficeArea[]

  @@index([active, sortOrder])
  @@map("area_catalog")
}

model OfficeArea {
  officeId  String
  areaId    String
  office    Office      @relation(fields: [officeId], references: [id], onDelete: Cascade)
  area      AreaCatalog @relation(fields: [areaId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@id([officeId, areaId])
  @@index([areaId])
  @@map("office_areas")
}

model PlanCatalog {
  id                  String    @id @default(uuid())
  slug                String    @unique
  nameHe              String
  nameEn              String?
  tagline             String?
  // Default billing values applied when a tenant is assigned this plan. The
  // AdminService overwrites the matching Tenant fields, so subsequent edits
  // to the plan don't retro-actively change existing tenants.
  setupFeeIls         Int       @default(0)
  monthlyPlanIls      Int       @default(0)
  includedMessages    Int       @default(0)
  includedCallMinutes Int       @default(0)
  monthlyLlmBudgetUsd Decimal   @default(0) @db.Decimal(10, 4)
  extraMessageIls     Decimal   @default(0) @db.Decimal(8, 2)
  extraCallMinuteIls  Decimal   @default(0) @db.Decimal(8, 2)
  successFeePct       Decimal   @default(0) @db.Decimal(5, 2)
  // Feature toggles (sign module, AI tier, branding, etc). Schema-less JSON
  // because the feature surface grows fast and we don't want a migration for
  // each new flag. UI knows the shape.
  features            Json      @default("{}")
  publishedAt         DateTime?
  active              Boolean   @default(true)
  sortOrder           Int       @default(100)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenants Tenant[]

  @@index([active, sortOrder])
  @@map("plan_catalog")
}

model User {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId     String?
  office       Office?    @relation(fields: [officeId], references: [id], onDelete: SetNull)
  name         String
  email        String
  phone        String?
  role         UserRole   @default(realtor)
  status       UserStatus @default(invited)
  passwordHash String?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  refreshTokens         RefreshToken[]
  activationTokens      ActivationToken[]
  passwordResetTokens   PasswordResetToken[]
  assignedLeads         Lead[]               @relation("LeadAssignee")
  assignedTasks         Task[]               @relation("TaskAssignee")
  notifications         Notification[]
  signDocumentsUploaded SignDocument[]       @relation("SignDocumentsUploaded")

  @@unique([tenantId, email])
  @@index([tenantId, officeId])
  @@map("users")
}

// One-time token sent to invited users to set their initial password and
// activate their account. Hashed at rest (same pattern as RefreshToken) so a
// leaked DB row can't be replayed.
model ActivationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("activation_tokens")
}

// One-time token issued by POST /auth/forgot-password. Short TTL (1h) and
// single-use. Hash-only storage, same as activation tokens.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorType  String
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model OptOut {
  id        String        @id @default(uuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone     String
  channel   OptOutChannel
  reason    String?
  createdAt DateTime      @default(now())

  @@unique([tenantId, phone, channel])
  @@index([tenantId, phone])
  @@map("opt_outs")
}

model Lead {
  id             String          @id @default(uuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId       String
  office         Office          @relation(fields: [officeId], references: [id], onDelete: Cascade)
  assignedUserId String?
  assignedUser   User?           @relation("LeadAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  source         String? // free text: "whatsapp", "form", "manual", "external_X"
  fullName       String?
  // National ID / Passport — populated lazily when a contract (e.g. bank
  // authorization letter) needs it. Optional everywhere else.
  nationalId     String?
  phone          String?
  email          String?
  intent         LeadIntent      @default(unknown)
  city           String?
  area           String?
  // Street + house number — only used for bank authorization forms today.
  // Lead-routing logic still uses `city`/`area` instead.
  streetAddress  String?
  budgetMin      Int?
  budgetMax      Int?
  rooms          Float?
  status         LeadStatus      @default(new)
  temperature    LeadTemperature @default(cold)
  nextFollowupAt DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  conversations   Conversation[]
  tasks           Task[]
  properties      Property[]
  mortgageProfile MortgageProfile?
  signDocuments   SignDocument[]   @relation("LeadSignDocuments")

  @@index([tenantId, officeId])
  @@index([tenantId, status])
  @@index([tenantId, temperature])
  @@index([tenantId, assignedUserId])
  @@index([tenantId, phone])
  @@map("leads")
}

model MortgageAdvisor {
  id                  String   @id @default(uuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName            String
  // Optional — only required when generating bank authorization letters
  // (each bank's כתב הסמכה form has slots for these). Stored once on the
  // advisor row so it's auto-filled into every future letter.
  nationalId          String?
  licenseNumber       String? // מספר רישיון יועץ משכנתאות מהאוצר
  consultingCompany   String? // שם חברת הייעוץ (אופציונלי — חלק מהיועצים עצמאיים)
  consultingCompanyId String? // ח.פ. של חברת הייעוץ
  company             String?
  phone               String?
  email               String?
  notes               String?
  status              String   @default("active") // active, paused
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  referrals MortgageReferral[]

  @@index([tenantId, status])
  @@map("mortgage_advisors")
}

model MortgageProfile {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId   String @unique
  lead     Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Minimal financial info — no documents, no sensitive IDs per spec section 29.
  estimatedPrice    Int? // budget for the property
  estimatedEquity   Int? // הון עצמי משוער
  hasPreApproval    Boolean @default(false)
  preApprovalAmount Int?
  preApprovalBank   String? // free text, no validation
  monthlyIncome     Int? // optional

  // Co-applicant ("לווה 2" in bank forms). Required by every bank auth
  // template when the mortgage has two borrowers. Kept here (not on Lead)
  // because the co-applicant is typically a spouse/partner, not a
  // separate CRM lead.
  coApplicantName       String?
  coApplicantNationalId String?
  coApplicantPhone      String?

  // Status and score
  status         MortgageStatus    @default(unknown)
  readinessScore Int? // 0-100
  readiness      MortgageReadiness @default(unknown)

  // Consent — required before sharing with any advisor
  consentToShareWithAdvisor Boolean   @default(false)
  consentTimestamp          DateTime?
  consentText               String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrals MortgageReferral[]

  @@index([tenantId, status])
  @@index([tenantId, readiness])
  @@map("mortgage_profiles")
}

model MortgageReferral {
  id                String          @id @default(uuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mortgageProfileId String
  profile           MortgageProfile @relation(fields: [mortgageProfileId], references: [id], onDelete: Cascade)
  advisorId         String
  advisor           MortgageAdvisor @relation(fields: [advisorId], references: [id], onDelete: Restrict)
  status            ReferralStatus  @default(pending)
  notes             String?
  referredAt        DateTime        @default(now())
  contactedAt       DateTime?
  closedAt          DateTime?
  updatedAt         DateTime        @updatedAt

  @@index([tenantId, status])
  @@index([advisorId, status])
  @@index([mortgageProfileId])
  @@map("mortgage_referrals")
}

model Property {
  id            String             @id @default(uuid())
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId      String
  office        Office             @relation(fields: [officeId], references: [id], onDelete: Cascade)
  ownerLeadId   String?
  ownerLead     Lead?              @relation(fields: [ownerLeadId], references: [id], onDelete: SetNull)
  dealType      PropertyDealType
  city          String?
  area          String?
  street        String?
  rooms         Float?
  floor         Int?
  price         Int?
  condition     PropertyCondition?
  coverImageUrl String?
  galleryUrls   Json?
  status        PropertyStatus     @default(draft)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  signDocuments SignDocument[] @relation("PropertySignDocuments")

  @@index([tenantId, officeId, status])
  @@index([tenantId, dealType])
  @@index([tenantId, ownerLeadId])
  @@map("properties")
}

model Agent {
  id          String      @id @default(uuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId    String?
  office      Office?     @relation(fields: [officeId], references: [id], onDelete: SetNull)
  type        AgentType
  name        String
  status      AgentStatus @default(paused)
  modelPolicy Json? // routing hints for LLM Router (e.g. {"primary":"groq","quality":"claude"})
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  configs       AgentConfig[]
  conversations Conversation[]

  @@index([tenantId, type])
  @@map("agents")
}

model AgentConfig {
  id           String   @id @default(uuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prompt       String
  rules        Json     @default("{}")
  tools        Json     @default("[]")
  handoffRules Json     @default("{}")
  version      Int      @default(1)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([agentId, isActive])
  @@index([tenantId, agentId])
  @@map("agent_configs")
}

model Conversation {
  id              String              @id @default(uuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId        String
  office          Office              @relation(fields: [officeId], references: [id], onDelete: Cascade)
  leadId          String?
  lead            Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  channel         ConversationChannel
  agentId         String?
  agent           Agent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  status          ConversationStatus  @default(active)
  startedAt       DateTime            @default(now())
  endedAt         DateTime?
  summary         String?
  handoffRequired Boolean             @default(false)
  metadata        Json?

  messages Message[]

  @@index([tenantId, officeId, status])
  @@index([tenantId, leadId])
  @@index([tenantId, agentId])
  @@map("conversations")
}

model Message {
  id             String            @id @default(uuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     MessageSenderType
  senderId       String?
  body           String
  metadata       Json?
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@index([tenantId, createdAt])
  @@map("messages")
}

model Notification {
  id        String               @id @default(uuid())
  tenantId  String
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId  String?
  office    Office?              @relation(fields: [officeId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      NotificationType
  severity  NotificationSeverity @default(info)
  title     String
  body      String?
  link      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([tenantId, userId, readAt, createdAt])
  @@index([tenantId, type, createdAt])
  @@map("notifications")
}

model UsageEvent {
  id             String         @id @default(uuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId       String?
  office         Office?        @relation(fields: [officeId], references: [id], onDelete: SetNull)
  agentId        String?
  conversationId String?
  type           UsageEventType
  provider       String? // "groq", "anthropic", "gemini", "twilio", "meta", "360dialog", "mock"
  quantity       Int            @default(1)
  costEstimate   Decimal?       @db.Decimal(12, 6)
  metadata       Json?
  createdAt      DateTime       @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, type, createdAt])
  @@index([tenantId, provider, createdAt])
  @@map("usage_events")
}

model Task {
  id             String            @id @default(uuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId       String
  office         Office            @relation(fields: [officeId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUserId String?
  assignedUser   User?             @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  type           TaskType          @default(custom)
  title          String
  description    String?
  status         TaskStatus        @default(open)
  dueAt          DateTime?
  createdByType  TaskCreatedByType @default(user)
  createdById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  completedAt    DateTime?

  @@index([tenantId, officeId, status])
  @@index([tenantId, assignedUserId, status])
  @@index([tenantId, leadId])
  @@index([tenantId, dueAt])
  @@map("tasks")
}

// ---------------------------------------------------------------------------
// Sign module — PDF signing platform integrated into realtorai. Documents
// belong to a Tenant (instead of a separate Organization model) and reuse
// the same User table. AuditLog uses the existing `action`/`targetType`
// pattern with targetType='sign_document' or 'sign_request'.
// ---------------------------------------------------------------------------

enum SignDocumentStatus {
  draft // uploaded, no signature_request yet
  sent // signature_request created, email out
  viewed // signer opened /sign/:token
  otp_verified // signer passed OTP step
  signed // submission complete, signed PDF stored
  declined // signer rejected explicitly (Phase 2)
  expired // token TTL elapsed without signing
  cancelled // tenant admin pulled the request
}

enum WebhookEndpointStatus {
  active
  disabled
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
  dead
}

model SignDocument {
  id                 String             @id @default(uuid())
  tenantId           String             @map("tenant_id")
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedByUserId   String             @map("uploaded_by_user_id")
  uploadedBy         User               @relation("SignDocumentsUploaded", fields: [uploadedByUserId], references: [id])
  // Optional CRM links — when the document is tied to a deal we know which
  // lead / property it belongs to so the UI can render contextual lists on
  // /leads/[id] and /properties/[id]. Both nullable so the existing standalone
  // upload flow keeps working unchanged.
  leadId             String?            @map("lead_id")
  lead               Lead?              @relation("LeadSignDocuments", fields: [leadId], references: [id], onDelete: SetNull)
  propertyId         String?            @map("property_id")
  property           Property?          @relation("PropertySignDocuments", fields: [propertyId], references: [id], onDelete: SetNull)
  originalFileName   String             @map("original_file_name")
  originalFilePath   String             @map("original_file_path")
  signedFilePath     String?            @map("signed_file_path")
  documentHash       String             @map("document_hash") // SHA-256 of original bytes
  signedDocumentHash String?            @map("signed_document_hash") // SHA-256 of signed bytes
  status             SignDocumentStatus @default(draft)
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  signatureRequest SignSignatureRequest?
  signature        SignSignature?

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([leadId])
  @@index([propertyId])
  @@map("sign_documents")
}

model SignSignatureRequest {
  id               String             @id @default(uuid())
  documentId       String             @unique @map("document_id")
  document         SignDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signerName       String             @map("signer_name")
  signerEmail      String             @map("signer_email")
  signerPhone      String?            @map("signer_phone")
  signingTokenHash String             @unique @map("signing_token_hash")
  tokenExpiresAt   DateTime           @map("token_expires_at")
  otpHash          String?            @map("otp_hash")
  otpExpiresAt     DateTime?          @map("otp_expires_at")
  otpAttempts      Int                @default(0) @map("otp_attempts")
  otpVerifiedAt    DateTime?          @map("otp_verified_at")
  signedAt         DateTime?          @map("signed_at")
  status           SignDocumentStatus @default(sent)
  createdAt        DateTime           @default(now()) @map("created_at")

  signature SignSignature?

  @@index([signingTokenHash])
  @@map("sign_signature_requests")
}

model SignSignature {
  id                 String               @id @default(uuid())
  documentId         String               @unique @map("document_id")
  document           SignDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatureRequestId String               @unique @map("signature_request_id")
  signatureRequest   SignSignatureRequest @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)
  signatureImagePath String               @map("signature_image_path")
  signerName         String               @map("signer_name")
  signerEmail        String               @map("signer_email")
  ipAddress          String?              @map("ip_address")
  userAgent          String?              @map("user_agent")
  signedAt           DateTime             @default(now()) @map("signed_at")

  @@map("sign_signatures")
}

model WebhookEndpoint {
  id          String                @id @default(uuid())
  tenantId    String                @map("tenant_id")
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url         String
  secret      String // HMAC-SHA256 signing secret
  eventFilter String[]              @default([]) @map("event_filter")
  status      WebhookEndpointStatus @default(active)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id               String                @id @default(uuid())
  tenantId         String                @map("tenant_id")
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpointId       String                @map("endpoint_id")
  endpoint         WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  eventType        String                @map("event_type")
  payload          Json
  status           WebhookDeliveryStatus @default(pending)
  attempts         Int                   @default(0)
  lastResponseCode Int?                  @map("last_response_code")
  lastError        String?               @map("last_error")
  nextAttemptAt    DateTime?             @map("next_attempt_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@index([nextAttemptAt])
  @@map("webhook_deliveries")
}

// ---------------------------------------------------------------------------
// Bank authorization templates — the original PDFs published by each bank
// for "כתב הסמכה ליועץ משכנתאות חיצוני". We don't modify the source PDFs;
// instead we render an overlay of values at recorded coordinates on top of
// the base file when a user generates a new letter.
//
// `overlay` is an array of field placements. Each entry says: "at page P,
// x=X, y=Y, write the value mapped to logical key K". The keys (borrower1_name,
// advisor_id, …) are stable across banks even though their positions differ.
//
// For PDFs that DO carry AcroForm widgets (currently just Discount + maybe
// Mercantile), we additionally store an `acroFormMap` so we can fill the
// existing fields by name instead of overlaying text.
// ---------------------------------------------------------------------------

model BankAuthTemplate {
  id          String   @id @default(uuid())
  bankSlug    String   @unique // 'discount' | 'leumi' | 'hapoalim' | ...
  bankNameHe  String // 'בנק דיסקונט'
  bankNameEn  String?
  pdfPath     String // path under apps/api/storage/sign/templates/
  // Layout of the overlay — see SignPdfOverlayService for the shape.
  // [{ key:'borrower1_name', page:0, x:380, y:720, fontSize:11, maxWidth:200, align:'right' }]
  overlay     Json     @default("[]")
  // For AcroForm-aware templates: { 'borrower1_name': 'Text1.0', ... }
  acroFormMap Json     @default("{}")
  active      Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bank_auth_templates")
}
