// Realtorai Prisma schema — Sprint 1
// Multi-tenant SaaS for real estate offices.
// All tenant-owned models carry tenantId. Tenant scoping is enforced at runtime
// by PrismaService's client extension (see src/prisma/tenant-extension.ts).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  platform_admin
  office_owner
  office_manager
  realtor
  viewer
}

enum TenantStatus {
  active
  suspended
  trial
}

enum OfficeStatus {
  active
  inactive
}

enum UserStatus {
  active
  invited
  disabled
}

enum OptOutChannel {
  whatsapp
  call
  sms
  email
}

model Tenant {
  id        String       @id @default(uuid())
  name      String
  status    TenantStatus @default(trial)
  plan      String       @default("starter")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  offices   Office[]
  users     User[]
  auditLogs AuditLog[]
  optOuts   OptOut[]

  @@map("tenants")
}

model Office {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  city           String?
  areas          String[]     @default([])
  phone          String?
  whatsappNumber String?
  status         OfficeStatus @default(active)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users User[]

  @@index([tenantId])
  @@map("offices")
}

model User {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId     String?
  office       Office?    @relation(fields: [officeId], references: [id], onDelete: SetNull)
  name         String
  email        String
  phone        String?
  role         UserRole   @default(realtor)
  status       UserStatus @default(invited)
  passwordHash String?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId, officeId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorType  String
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model OptOut {
  id        String        @id @default(uuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone     String
  channel   OptOutChannel
  reason    String?
  createdAt DateTime      @default(now())

  @@unique([tenantId, phone, channel])
  @@index([tenantId, phone])
  @@map("opt_outs")
}
