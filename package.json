{
  "name": "realtorai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "api:dev": "pnpm --filter @realtorai/api dev",
    "api:build": "pnpm --filter @realtorai/api build",
    "api:start": "pnpm --filter @realtorai/api start",
    "api:test": "pnpm --filter @realtorai/api test",
    "api:test:e2e": "pnpm --filter @realtorai/api test:e2e",
    "api:prisma": "pnpm --filter @realtorai/api prisma",
    "infra:up": "docker compose -f infra/docker-compose.dev.yml --env-file infra/.env up -d",
    "infra:down": "docker compose -f infra/docker-compose.dev.yml --env-file infra/.env down",
    "infra:logs": "docker compose -f infra/docker-compose.dev.yml --env-file infra/.env logs -f",
    "infra:psql": "docker compose -f infra/docker-compose.dev.yml --env-file infra/.env exec postgres psql -U realtorai -d realtorai",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "lint": "pnpm --filter @realtorai/api lint"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
